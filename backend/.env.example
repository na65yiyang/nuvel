# ─────────────────────────────────────────────────────────────────────────────
# Nuvel Backend — Environment Variables
# Copy this file to .env and fill in the values before running locally.
# On Railway, set these in the service's "Variables" tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Railway auto-injects PORT. Leave blank locally (Dockerfile defaults to 8000).
PORT=

# ── Redis ────────────────────────────────────────────────────────────────────
# Celery broker + result backend + WebSocket pub/sub.
# Railway Redis plugin provides this automatically as REDIS_URL.
REDIS_URL=redis://localhost:6379/0

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Used by the RAG pipeline (query_with_citation) and footnote scanner.
# Obtain at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── AlphaVantage ─────────────────────────────────────────────────────────────
# Used to fetch annual income statements, balance sheets, and cash-flow data.
# Free tier: 25 requests/day, 5 requests/minute.
# Obtain at: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Object storage for completed report JSON and Excel workbooks.
# Create a bucket and API token in the Cloudflare dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nuvel-reports

# ── Supabase ─────────────────────────────────────────────────────────────────
# PostgreSQL database for report metadata and user records.
# Obtain from: Project Settings → API in the Supabase dashboard.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
