# ─────────────────────────────────────────────────────────────────────────────
# Nuvel Frontend — Environment Variables
# Set these in Vercel → Project → Settings → Environment Variables.
# For local dev copy to .env.local (already present in the repo).
# ─────────────────────────────────────────────────────────────────────────────

# HTTP base URL for all /api/* fetch calls (no trailing slash)
# Example: https://nuvel-backend.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket base URL for /ws/* connections (no trailing slash)
# Example: wss://nuvel-backend.railway.app
NEXT_PUBLIC_WS_URL=ws://localhost:8000
